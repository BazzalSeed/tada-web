# Tada Web — environment template. Safe to commit (no real secrets).
# Copy to your local secrets file:  cp .env.example .env.local

# ── Database ───────────────────────────────────────────────────────────
# Local dev = the bundled Docker Postgres (`docker compose up db`, see docs/DOCKER.md).
# DATABASE_URL is pooled (app runtime); DIRECT_URL is non-pooled (Prisma migrations).
# Locally both point at the same Postgres. In production (Vercel) these are set to Neon.
DATABASE_URL="postgresql://tada:tada@localhost:5432/tada"
DIRECT_URL="postgresql://tada:tada@localhost:5432/tada"

# ── AI providers ───────────────────────────────────────────────────────
GEMINI_API_KEY=""             # Gemini — extraction / enrichment / chat / research
OPENAI_API_KEY=""             # OpenAI Realtime — voice only
# OPENAI_REALTIME_MODEL=""    # optional: override the realtime voice model

# ── Auth.js (NextAuth v5) + Google OAuth ───────────────────────────────
AUTH_SECRET=""                # generate: openssl rand -base64 33
AUTH_GOOGLE_ID=""             # Google OAuth client id  (Calendar + contacts scopes)
AUTH_GOOGLE_SECRET=""         # Google OAuth client secret
# AUTH_TRUST_HOST=true        # set when running behind a proxy / non-localhost host

# Sign in locally without Google (non-prod only) — then visit /dev-login
ENABLE_DEV_LOGIN="1"
DEV_LOGIN_EMAIL="you@example.com"

# Admin allowlist — these emails bypass the invite gate and get plan=unlimited
ADMIN_EMAILS="you@example.com"

# ── Storage ────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=""      # Vercel Blob — capture images

# ── Optional ───────────────────────────────────────────────────────────
# POSTMARK_INBOUND_WEBHOOK_SECRET=""  # forward-an-email capture (built but dormant)
# TADA_TIMEZONE=""                    # override server timezone for date parsing
