// Tada Web v0 — Prisma schema for the full frozen data model.
// Mirrors lib/contracts/types.ts. Enums stored as String columns (typed in TS
// via the contract union types). Wire keys are snake_case via @map; TS fields
// are camelCase. JSON columns hold tagged/structured values (actionPayload,
// recurrence, criteria). One owner (userId) per app entity.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (app runtime)
  directUrl = env("DIRECT_URL")   // non-pooled (migrations)
}

// ============================================================================
// App domain
// ============================================================================

model Todo {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  sourceCaptureId  String    @map("source_capture_id")
  title            String
  detail           String?
  status           String    @default("open") // TodoStatus: open|done|dismissed
  actionType       String    @default("none") @map("action_type") // none|meeting|reminder|research
  actionPayload    Json?     @map("action_payload")
  actionState      String    @default("none") @map("action_state") // none|proposed|running|done|failed|needs_disambiguation
  actionExternalId String?   @map("action_external_id")
  dueAt            DateTime? @map("due_at")
  sortIndex        Float     @map("sort_index") // fractional; lower sorts higher
  priority         String    @default("none") // none|p1|p2|p3
  listId           String?   @map("list_id") // null = Inbox/All
  labelIds         String[]  @map("label_ids")
  recurrence       Json?
  parentId         String?   @map("parent_id") // one-level subtasks
  reminderAt       DateTime? @map("remind_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  capture  Capture  @relation(fields: [sourceCaptureId], references: [id], onDelete: Cascade)
  parent   Todo?    @relation("Subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  children Todo[]   @relation("Subtasks")

  @@index([userId])
  @@index([userId, status])
  @@index([parentId])
  @@index([sourceCaptureId])
  @@map("todos")
}

model Capture {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  kind      String // image|text|file|email
  blobPath  String?  @map("blob_path")
  note      String?

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  todos Todo[]

  @@index([userId])
  @@map("captures")
}

model TodoLabel {
  id       String @id @default(cuid())
  userId   String @map("user_id")
  name     String // lowercased
  colorHex String @map("color_hex")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("todo_labels")
}

model SavedView {
  id        String @id @default(cuid())
  userId    String @map("user_id")
  name      String
  colorHex  String @map("color_hex")
  icon      String
  sortIndex Float  @map("sort_index")
  criteria  Json // FilterCriteria

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("saved_views")
}

// ============================================================================
// Chat — persisted agent conversations (text chat; voice can land here later).
// One Conversation = one thread the user sees; `summary`/`summaryThroughId` hold
// the Layer-2 rolling-compaction state (see lib/chat/context.ts). Messages store
// the full AI SDK UIMessage shape (parts: text + tool calls/results) so tool
// tiles re-render verbatim on reload. The model only ever receives a bounded
// slice (summary + pruned recent tail); the DB keeps every raw message.
// ============================================================================

model Conversation {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  title            String? // null until the first turn names it
  summary          String? // rolling summary of turns older than the tail
  summaryThroughId String?  @map("summary_through_id") // watermark: last message folded into `summary`
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId, updatedAt])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  role           String // user|assistant|system
  parts          Json // AI SDK UIMessage.parts (text + tool-invocation parts)
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ============================================================================
// Accounts & auth (Auth.js / NextAuth Prisma adapter shape)
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime? @map("email_verified")
  plan          String    @default("free") // free|pro|unlimited
  timezone      String?   // IANA zone captured from the browser; used to anchor bookings
  createdAt     DateTime  @default(now()) @map("created_at")

  accounts Account[]
  sessions Session[]
  todos         Todo[]
  captures      Capture[]
  labels        TodoLabel[]
  views         SavedView[]
  aiUsage       AiUsage[]
  conversations Conversation[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================================
// Quota
// ============================================================================

model AiUsage {
  userId    String   @map("user_id")
  period    String // 'YYYY-MM'
  used      Int      @default(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, period])
  @@map("ai_usage")
}
