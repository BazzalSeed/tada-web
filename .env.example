# Tada Web — environment template. Safe to commit (no real secrets).
# Copy to .env and fill in. See docs/superpowers/specs for what each phase needs.

# Neon Postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"
# DIRECT_URL=""   # non-pooled URL for Prisma migrations (optional)

# AI providers (Gemini = image+text, OpenAI = voice)
GEMINI_API_KEY=""
OPENAI_API_KEY=""

# Auth.js + Google OAuth (Gmail/Calendar)
AUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Admin allowlist — these emails bypass the invite gate and get plan=unlimited
ADMIN_EMAILS="seedzpy@gmail.com"

# Vercel Blob (capture images)
BLOB_READ_WRITE_TOKEN=""

# Postmark inbound (forward-an-email capture)
POSTMARK_SERVER_TOKEN=""
